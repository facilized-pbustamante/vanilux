#!/bin/sh
set -e

APP="vanilux"
BIN="/usr/bin/$APP"
APPS_DIR="/usr/share/applications"
CONFIG_DIR="$HOME/.config/vanilux"
CONFIG_FILE="$CONFIG_DIR/config.txt"

mkdir -p "$APPS_DIR"
cat > "$APPS_DIR/$APP.desktop" <<EOF
[Desktop Entry]
Type=Application
Version=1.0
Name=Vanilux
GenericName=Application Launcher
Comment=Lanzador de aplicaciones a pantalla completa (estilo Launchpad)
Exec=$BIN
Icon=/usr/share/vanilux/icons/grid_amber.svg
Terminal=false
Categories=Utility;
Keywords=launcher;apps;menu;lanzador;aplicaciones;
StartupNotify=false
EOF
update-desktop-database "$APPS_DIR" >/dev/null 2>&1 || true

# Crear config por defecto (solo si no existe)
mkdir -p "$CONFIG_DIR"
if [ ! -f "$CONFIG_FILE" ]; then
  cat > "$CONFIG_FILE" <<EOF2
color=#e09924
hotkey=F4
lang=EN
EOF2
fi

# Configurar atajo F4 en segundo plano (sin preguntar)
HOTKEY="F4"
if command -v gsettings >/dev/null 2>&1; then
  schemas="$(gsettings list-schemas 2>/dev/null || true)"
  if printf '%s\n' "$schemas" | grep -qx "org.cinnamon.desktop.keybindings"; then
    s="org.cinnamon.desktop.keybindings"
    relo="org.cinnamon.desktop.keybindings.custom-keybinding"
    p="/org/cinnamon/desktop/keybindings/custom-keybindings/vanilux/"
    cur="$(gsettings get "$s" custom-list 2>/dev/null || echo '@as []')"
    case "$cur" in
      *"'vanilux'"*) : ;;
      "@as []"|"[]"|"") gsettings set "$s" custom-list "['vanilux']" ;;
      *) gsettings set "$s" custom-list "${cur%]}, 'vanilux']" ;;
    esac
    gsettings set "$relo:$p" name "'Vanilux'"
    gsettings set "$relo:$p" command "'$BIN'"
    gsettings set "$relo:$p" binding "['$HOTKEY']"
  elif printf '%s\n' "$schemas" | grep -qx "org.gnome.settings-daemon.plugins.media-keys"; then
    s="org.gnome.settings-daemon.plugins.media-keys"
    relo="org.gnome.settings-daemon.plugins.media-keys.custom-keybinding"
    p="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/vanilux/"
    cur="$(gsettings get "$s" custom-keybindings 2>/dev/null || echo '@as []')"
    case "$cur" in
      *"$p"*) : ;;
      "@as []"|"[]"|"") gsettings set "$s" custom-keybindings "['$p']" ;;
      *) gsettings set "$s" custom-keybindings "${cur%]}, '$p']" ;;
    esac
    gsettings set "$relo:$p" name 'Vanilux'
    gsettings set "$relo:$p" command "$BIN"
    gsettings set "$relo:$p" binding "['$HOTKEY']"
  elif command -v xfconf-query >/dev/null 2>&1; then
    xfconf-query -c xfce4-keyboard-shortcuts -n -t string -p "/commands/custom/$HOTKEY" -s "$BIN" 2>/dev/null || \
    xfconf-query -c xfce4-keyboard-shortcuts -t string -p "/commands/custom/$HOTKEY" -s "$BIN" 2>/dev/null || true
  fi
fi

killall "$APP" 2>/dev/null || true
exit 0
